# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Required for real AI generation (leave blank to stay in mock mode).
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Feature flags — set to true to enable. Default is false (mock mode).
# real_ai_generation: switches from mock cards to live Claude API
NEXT_PUBLIC_FLAG_REAL_AI_GENERATION=false
# advanced_outputs: enables blog summary, timestamps, short-form script + alt hook selection (leave off for first test)
NEXT_PUBLIC_FLAG_ADVANCED_OUTPUTS=false
# dev_debug: shows AI diagnostics panel in the UI — developer only
NEXT_PUBLIC_FLAG_DEV_DEBUG=false

# The public URL of your deployed app — used for absolute OG/Twitter metadata.
# Leave as-is for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — required for auth (AUTH-A).
# Get these from your Supabase project: dashboard → Settings → API.
# Add to Supabase Auth → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback      (local dev)
#   https://virnix.pro/auth/callback         (production non-www)
#   https://www.virnix.pro/auth/callback     (production www — production uses www, both required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   ← never expose to the client; only add if a server admin route requires it
