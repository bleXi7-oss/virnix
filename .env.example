# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Required for real AI generation (leave blank to stay in mock mode).
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Feature flags — set to true to enable. Default is false (mock mode).
# real_ai_generation: switches from mock cards to live Claude API
NEXT_PUBLIC_FLAG_REAL_AI_GENERATION=false
# advanced_outputs: enables blog summary, timestamps, short-form script (leave off for first test)
NEXT_PUBLIC_FLAG_ADVANCED_OUTPUTS=false

# The public URL of your deployed app — used for absolute OG/Twitter metadata.
# Leave as-is for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
